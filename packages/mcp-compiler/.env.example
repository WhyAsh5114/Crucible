# mcp-compiler environment variables

# Port for the compiler MCP server (default: 3101, matches ARCHITECTURE.md)
COMPILER_MCP_PORT=3101

# Set to 'true' to bypass solc-js entirely and return fixture data.
# Use this for local frontend / agent development without a real compiler.
# Maps to the MOCK_COMPILER stub described in docs/PLAN.md.
MOCK_COMPILER=false

# Absolute path to the workspace root directory.
# Source files passed to 'compile' are resolved relative to this path.
# Defaults to the process working directory if unset.
# Example (local dev):   WORKSPACE_ROOT=./data/workspaces/<workspaceId>
# Example (hosted):      WORKSPACE_ROOT=/var/lib/crucible/workspaces/<workspaceId>
WORKSPACE_ROOT=
