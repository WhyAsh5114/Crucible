{
  "name": "@crucible/backend",
  "version": "0.0.0",
  "private": true,
  "description": "Crucible backend package.",
  "license": "UNLICENSED",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "postinstall": "bunx --bun prisma generate"
  },
  "dependencies": {
    "@crucible/types": "workspace:*",
    "@hono/zod-openapi": "^1.3.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.9",
    "dockerode": "^4.0.9",
    "dotenv": "^17.4.2",
    "hono": "^4.12.15",
    "pg": "^8.20.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/dockerode": "^3.3.44",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
