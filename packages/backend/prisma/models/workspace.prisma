enum RuntimeStatus {
    ready
    crashed
    stopped
    starting
    degraded
}

model Workspace {
    id            String            @id @default(cuid())
    name          String
    directoryPath String            @unique
    userId        String
    user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt     DateTime          @default(now())
    updatedAt     DateTime          @updatedAt
    deployments   Json              @default("[]")
    runtime       WorkspaceRuntime?
    chatSessions  ChatSession[]

    @@index([userId])
    @@map("workspace")
}

model WorkspaceRuntime {
    runtimeId         String        @id @default(cuid())
    workspaceId       String        @unique
    workspace         Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
    status            RuntimeStatus
    startedAt         DateTime
    previewUrl        String?
    terminalSessionId String?
    chainPort         Int?
    compilerPort      Int?
    deployerPort      Int?
    walletPort        Int?
    memoryPort        Int?
    meshPort          Int?
    terminalPort      Int?
    devtoolsPort      Int?
    chainState        Json?
    /** AXL public key registered by mcp-mesh on startup. Null until mcp-mesh
     *  has started and called POST /api/workspace/:id/axl-key. Used by peer
     *  workspaces to discover each other's AXL identity for P2P messaging. */
    axlPublicKey      String?
    createdAt         DateTime      @default(now())
    updatedAt         DateTime      @updatedAt

    @@index([status])
    @@map("workspace_runtime")
}

model ChatSession {
    id          String    @id @default(cuid())
    workspaceId String
    workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
    title       String    @default("New Chat")
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    @@index([workspaceId])
    @@map("chat_session")
}
