enum RuntimeStatus {
    ready
    crashed
    stopped
    starting
    degraded
}

model Workspace {
    id            String            @id @default(cuid())
    name          String
    directoryPath String            @unique
    userId        String
    user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt     DateTime          @default(now())
    updatedAt     DateTime          @updatedAt
    deployments   Json              @default("[]")
    /// Initial scaffold template used to provision the workspace. Persisted
    /// so the per-boot auto-deploy + scaffold-overlay re-runs against the
    /// same template after backend restarts. Defaults to 'counter' so older
    /// rows (created before this column existed) keep their existing
    /// DemoVault scaffold behaviour unchanged.
    template      String            @default("counter")
    runtime       WorkspaceRuntime?
    chatSessions  ChatSession[]

    @@index([userId])
    @@map("workspace")
}

model WorkspaceRuntime {
    runtimeId         String        @id @default(cuid())
    workspaceId       String        @unique
    workspace         Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
    status            RuntimeStatus
    startedAt         DateTime
    previewUrl        String?
    terminalSessionId String?
    chainPort         Int?
    compilerPort      Int?
    deployerPort      Int?
    walletPort        Int?
    memoryPort        Int?
    terminalPort      Int?
    devtoolsPort      Int?
    chainState        Json?
    createdAt         DateTime      @default(now())
    updatedAt         DateTime      @updatedAt

    @@index([status])
    @@map("workspace_runtime")
}

model ChatSession {
    id          String    @id @default(cuid())
    workspaceId String
    workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
    title       String    @default("New Chat")
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    @@index([workspaceId])
    @@map("chat_session")
}
