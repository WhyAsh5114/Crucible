# ── Hono Server ───────────────────────────────────────────────────────────────

# Port to run the Hono server on
PORT = 5000

# Base URL of this server — used by Better Auth for callbacks & CORS
BETTER_AUTH_URL=http://localhost:5000

# Better Auth — min 32 chars, generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# PostgreSQL — postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# Persistent host path used for per-workspace runtime files
CRUCIBLE_WORKSPACES_ROOT=/var/lib/crucible/workspaces

# Runtime image used for per-workspace containers
CRUCIBLE_RUNTIME_IMAGE=ubuntu:24.04

# Workspace mount mode: bind (local host path) or volume (named Docker volume)
CRUCIBLE_RUNTIME_MOUNT_MODE=bind

# Optional host root override for bind mode; leave empty to use CRUCIBLE_WORKSPACES_ROOT
CRUCIBLE_RUNTIME_BIND_ROOT=

# Named Docker volume used when mount mode is volume
CRUCIBLE_WORKSPACES_VOLUME=crucible-workspaces-data

# Container path used as the volume mount root when mount mode is volume
CRUCIBLE_RUNTIME_VOLUME_ROOT=/workspace-root

# Runtime Docker operation controls
CRUCIBLE_DOCKER_RETRY_COUNT=2
CRUCIBLE_DOCKER_TIMEOUT_MS=15000

# OAuth credentials for Google provider
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
