# ── Hono Server ───────────────────────────────────────────────────────────────

# Port to run the Hono server on. Must match the proxy target in
# packages/frontend/vite.config.ts (currently http://localhost:3000).
PORT=3000

# Base URL of this server — used by Better Auth for callbacks & CORS
BETTER_AUTH_URL=http://localhost:3000

# Better Auth — min 32 chars, generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# SIWE domain — RFC 3986 authority that the frontend embeds in the EIP-4361
# message. Must match the host the user signs against (i.e. the user-facing
# origin, not the API port). If unset, derived from CRUCIBLE_FRONTEND_ORIGIN.
# Local dev (Vite proxy):    SIWE_DOMAIN=localhost:5173
# Hosted (shared host):      SIWE_DOMAIN=crucible.yourdomain.com
SIWE_DOMAIN=

# PostgreSQL — postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# Persistent host path used for per-workspace runtime files
CRUCIBLE_WORKSPACES_ROOT=/var/lib/crucible/workspaces

# Runtime image used for per-workspace containers
CRUCIBLE_RUNTIME_IMAGE=crucible-runtime:latest

# Workspace mount mode: bind (local host path) or volume (named Docker volume)
CRUCIBLE_RUNTIME_MOUNT_MODE=bind

# Optional host root override for bind mode; leave empty to use CRUCIBLE_WORKSPACES_ROOT
CRUCIBLE_RUNTIME_BIND_ROOT=

# Named Docker volume used when mount mode is volume
CRUCIBLE_WORKSPACES_VOLUME=crucible-workspaces-data

# Container path used as the volume mount root when mount mode is volume
CRUCIBLE_RUNTIME_VOLUME_ROOT=/workspace-root

# Runtime Docker operation controls
CRUCIBLE_DOCKER_RETRY_COUNT=2
CRUCIBLE_DOCKER_TIMEOUT_MS=15000

# Host the control plane uses to reach in-container MCP services. Override
# when the Docker daemon is on a different host (e.g. remote, host.docker.internal).
CRUCIBLE_RUNTIME_HOST=127.0.0.1

# How long to wait for the in-container chain/compiler services to answer
# HTTP before marking the runtime as `degraded` instead of `ready`.
CRUCIBLE_RUNTIME_READY_TIMEOUT_MS=60000
CRUCIBLE_RUNTIME_READY_INTERVAL_MS=500

# CORS origin for the frontend shell.
# Portless local dev: https://crucible.localhost
# Raw SvelteKit dev:   http://localhost:5173
CRUCIBLE_FRONTEND_ORIGIN=http://localhost:5173

# Optional regex pattern matched against the request Origin header to allow
# preview subdomain origins. Leave unset to disallow preview CORS requests.
# Example (Portless local): ^https://preview\.[a-z0-9][a-z0-9-]{0,62}\.crucible\.localhost$
# Example (hosted):         ^https://preview-[a-z0-9][a-z0-9-]{0,62}\.crucible\.yourdomain\.com$
CRUCIBLE_PREVIEW_ORIGIN_PATTERN=

# OAuth credentials for Google provider.
# Optional — if absent the server starts without Google login.
# Set both to enable Google social login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Sepolia deployment — mcp-deployer ─────────────────────────────────────────
# EOA private key used to sign and broadcast Sepolia deployments.
# Must have Sepolia ETH. Required for deployer.deploy_sepolia.
SEPOLIA_DEPLOY_PRIVATE_KEY=
# Sepolia JSON-RPC endpoint. Defaults to https://rpc.ankr.com/eth_sepolia if unset.
SEPOLIA_RPC_URL=

# ── KeeperHub — post-deploy automation MCP ────────────────────────────────────
# Org API key (kh_ prefix) from https://app.keeperhub.com.
# When set, the agent connects to KeeperHub's hosted MCP on every turn and
# exposes the full keeperhub_* tool surface (workflows, AI generation, wallet
# integrations, direct execution, action-schema discovery) to the model.
# Deploy to Sepolia first (SEPOLIA_DEPLOY_PRIVATE_KEY above), then use
# keeperhub_* tools to wire automation against the deployed contract address.
KEEPERHUB_API_KEY=
# Override the KeeperHub MCP endpoint. Defaults to https://app.keeperhub.com/mcp.
KEEPERHUB_MCP_URL=
