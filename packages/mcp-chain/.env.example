# mcp-chain environment variables

# Port for the chain MCP server (default: 3100, matches ARCHITECTURE.md)
CHAIN_MCP_PORT=3100

# Set to 'true' to bypass Hardhat entirely and return fixture data.
# Use this for local frontend / agent development without a running chain node.
# Maps to the MOCK_CHAIN stub described in docs/PLAN.md.
MOCK_CHAIN=false
