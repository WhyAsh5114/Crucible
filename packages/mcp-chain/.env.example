# mcp-chain environment variables

# Port for the chain MCP server (default: 3100, matches ARCHITECTURE.md)
CHAIN_MCP_PORT=3100

# When running via 'bun run dev', the server is accessible at:
#   https://chain.crucible.localhost
# (portless proxies this to 127.0.0.1:3100 automatically)

# Comma-separated hostnames allowed in the Host header (DNS rebinding protection).
# Add your machine's Tailscale hostname or IP here when accessing remotely.
# ALLOWED_HOSTS=macbook,100.x.y.z

# Default fork RPC — used when the model calls start_node/fork without specifying rpcUrl.
# Prefer Sepolia for general testing; only switch to mainnet when you need live mainnet state.
# DEFAULT_FORK_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
