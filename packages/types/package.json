{
  "name": "@crucible/types",
  "version": "0.0.0",
  "private": true,
  "description": "Frozen type contracts shared across all Crucible packages.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./mcp/*": {
      "types": "./src/mcp/*.ts",
      "default": "./src/mcp/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "viem": "^2.21.55",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
